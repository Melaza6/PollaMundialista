NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://polla.melazausa.com

# Change these before going live. Values belong in local .env or Vercel Environment Variables.
ADMIN_PIN=
SESSION_SECRET=

# Real fixture/result sync. API keys are server-side only.
# Primary provider: API-Football by API-SPORTS.
FOOTBALL_API_PROVIDER=auto
API_FOOTBALL_KEY=
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Fallback provider if API-Football is unavailable or plan-blocked.
FOOTBALL_DATA_API_KEY=

# Exchange-rate sync. Fallback uses DEFAULT_USD_COP_RATE when TRM is unavailable.
EXCHANGE_RATE_PROVIDER=datos-gov-co
EXCHANGE_RATE_FALLBACK_PROVIDER=default-estimate
DEFAULT_USD_COP_RATE=4000

# Data storage. Use supabase in production; json is local fallback only.
DATA_STORAGE_DRIVER=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Vercel dashboard feature toggles/documentation flags. Do not put secrets here.
ENABLE_VERCEL_ANALYTICS=true
ENABLE_VERCEL_SPEED_INSIGHTS=true
